# ── Required ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Simli.com — animated face (no GPU needed) ──────────────────────────────
SIMLI_API_KEY=...
SIMLI_FACE_ID=d2a5c7c6-fed9-4f55-bcb3-062f7cd20103

# ── TTS — pick one ─────────────────────────────────────────────────────────
# Option A: OpenAI TTS (uses same OPENAI_API_KEY above — no extra account)
# Voice options: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=nova

# Option B: ElevenLabs voice clone (optional — better quality, needs your voice recording)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Storage ─────────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
DB_PATH=./data/conversations.db

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000
